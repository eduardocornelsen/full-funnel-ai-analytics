      },
      "name": "Slack Alert",
      "type": "n8n-nodes-base.slack",
      "position": [850, 200]
    }
  ],
  "connections": {
    "ML Score API": {
      "main": [
        [
          {
            "node": "High Score?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
